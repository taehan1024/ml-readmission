# .streamlit/secrets.toml
# Copy this file to .streamlit/secrets.toml and fill in your deployed API URL.
# secrets.toml is gitignored — set these in Streamlit Community Cloud's
# "Secrets" panel under App Settings when deploying.

# URL of the deployed FastAPI service (Railway, Render, etc.)
FASTAPI_URL = "https://your-api.up.railway.app"
