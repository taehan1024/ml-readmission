# MLflow tracking server URI
# Use "http://localhost:5000" when running via docker-compose
# Use "http://mlflow:5000" when running inside docker network
MLFLOW_TRACKING_URI=http://localhost:5000

# Registered model name in MLflow model registry
MODEL_NAME=readmission-model

# Model stage to load from registry (Production, Staging, None)
MODEL_STAGE=Production

# Fallback local model path (relative to project root)
MODEL_LOCAL_PATH=models/model.pkl

# Optional: HTTPS URL to download model.pkl at container startup.
# Use a GitHub Release asset URL after uploading your trained model.
# Leave empty when running locally (model is already on disk).
MODEL_DOWNLOAD_URL=

# Whether to log every prediction to SQLite (true/false)
LOG_PREDICTIONS=true

# SQLite database path for prediction monitoring
MONITORING_DB_PATH=data/predictions.db

# API host and port (used by uvicorn)
API_HOST=0.0.0.0
API_PORT=8000
